# Database Configuration
# Leave DATABASE_URL blank to automatically use local SQLite database
# Set DATABASE_URL if you want to connect to a remote PostgreSQL database (like Neon)
DATABASE_URL=

# Django Secret Key (Generate a random string for local development)
SECRET_KEY=django-insecure-example-key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
