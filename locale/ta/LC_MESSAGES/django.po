msgstr "பதிவேற்றம் செய்து முடிக்கவும்"

msgid "DISPATCHED"
msgstr "அனுப்பப்பட்டது"

msgid "You must be within 50 meters of the destination to mark delivered."
msgstr ""
"டெலிவரி செய்யப்பட்டதாகக் குறிக்க, சேருமிடத்திலிருந்து 50 மீட்டருக்குள் "
"இருக்க வேண்டும்."

msgid "Enter your temporary password"
msgstr "உங்கள் தற்காலிக கடவுச்சொல்லை உள்ளிடவும்"

msgid "Order"
msgstr "ஆர்டர்"

msgid "Client"
msgstr "வாடிக்கையாளர்"

msgid "Managers"
msgstr "மேலாளர்கள்"

msgid "Shipments"
msgstr "ஏற்றுமதி"

msgid "Mark as Delivered"
msgstr "வழங்கப்பட்டதாகக் குறிக்கவும்"

msgid "Change Password"
msgstr "கடவுச்சொல்லை மாற்றவும்"

msgid "Start Delivery"
msgstr "விநியோகத்தைத் தொடங்கவும்"
