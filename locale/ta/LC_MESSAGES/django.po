msgstr "ஓட்டுனர்கள்"

msgid "Products"
msgstr "தயாரிப்புகள்"

msgid "Password"
msgstr "கடவுச்சொல்"

msgid "GPS Active"
msgstr "ஜிபிஎஸ் செயலில் உள்ளது"

